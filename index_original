<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>ILovePlaylist – Track Your YouTube Learning Progress</title>
    <meta name="description" content="ILovePlaylist helps you organize, track, and manage your YouTube playlist learning progress. Auto-fetch playlists, mark videos as complete, export CSV, and stay motivated.">
    <meta name="keywords" content="youtube playlist tracker, learning progress, video tracker, playlist manager, online learning">
    <meta name="author" content="HRS">
    <meta property="og:title" content="ILovePlaylist – YouTube Playlist Tracker">
    <meta property="og:description" content="Track your YouTube playlist progress like a pro. Auto-fetch videos, manage status, export your data.">
    <meta property="og:type" content="website">
    <meta name="theme-color" content="#e63946">
    <link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 100 100%22><text y=%22.9em%22 font-size=%2290%22>🎬</text></svg>">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="styles.css">
</head>
<body>

    <!-- Toast Container -->
    <div id="toastContainer" class="toast-container" aria-live="polite"></div>

    <!-- Navbar -->
    <nav class="navbar" role="navigation" aria-label="Main navigation">
        <div class="nav-inner">
            <a class="logo" href="/" aria-label="ILovePlaylist Home">
                <span class="logo-icon">🎬</span>
                <span class="logo-text">
                    <span class="logo-i">I</span><span class="logo-love">Love</span><span class="logo-product">Playlist</span>
                </span>
            </a>
            <div class="nav-actions">
                <button id="darkModeToggle" class="icon-btn" aria-label="Toggle dark mode" title="Toggle dark mode" onclick="toggleDarkMode()">
                    <span id="darkModeIcon">🌙</span>
                </button>
                <a href="https://www.linkedin.com/in/harsh-kumar-b0b879245/" target="_blank" rel="noopener" class="nav-link" aria-label="Created by HRS on LinkedIn">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" width="18" height="18"><path d="M20.5 2h-17A1.5 1.5 0 002 3.5v17A1.5 1.5 0 003.5 22h17a1.5 1.5 0 001.5-1.5v-17A1.5 1.5 0 0020.5 2zM8 19H5v-9h3zM6.5 8.25A1.75 1.75 0 118.3 6.5a1.78 1.78 0 01-1.8 1.75zM19 19h-3v-4.74c0-1.42-.6-1.93-1.38-1.93A1.74 1.74 0 0013 14.19a.66.66 0 000 .14V19h-3v-9h2.9v1.3a3.11 3.11 0 012.7-1.4c1.55 0 3.36.86 3.36 3.66z"/></svg>
                    By HRS
                </a>
            </div>
        </div>
    </nav>

    <!-- Hero Section -->
    <header class="hero" role="banner">
        <div class="hero-inner">
            <div class="hero-badge">🚀 Free YouTube Playlist Tracker</div>
            <h1 class="hero-title">
                Track Your <span class="highlight">Playlist</span> Progress
            </h1>
            <p class="hero-subtitle">
                Organize your YouTube learning journey. Auto-fetch entire playlists, track video status, take notes, and export your progress — all in one place.
            </p>
        </div>
    </header>

    <main class="main-content" role="main">

        <!-- Stats Section -->
        <section class="stats-section" aria-label="Progress Statistics">
            <div class="stats-grid">
                <div class="stat-card" id="statTotal">
                    <div class="stat-icon">📺</div>
                    <div class="stat-number" id="totalVideos">0</div>
                    <div class="stat-label">Total Videos</div>
                </div>
                <div class="stat-card stat-completed" id="statCompleted">
                    <div class="stat-icon">✅</div>
                    <div class="stat-number" id="completedVideos">0</div>
                    <div class="stat-label">Completed</div>
                </div>
                <div class="stat-card stat-progress" id="statProgress">
                    <div class="stat-icon">⚡</div>
                    <div class="stat-number" id="inProgressVideos">0</div>
                    <div class="stat-label">In Progress</div>
                </div>
                <div class="stat-card stat-percent" id="statPercent">
                    <div class="stat-icon">🎯</div>
                    <div class="stat-number" id="progressPercentage">0%</div>
                    <div class="stat-label">Completion</div>
                </div>
            </div>
            <!-- Overall Progress Bar -->
            <div class="progress-section" aria-label="Overall completion progress">
                <div class="progress-header">
                    <span class="progress-label">Overall Progress</span>
                    <span class="progress-value" id="progressLabel">0 / 0 videos</span>
                </div>
                <div class="progress-bar" role="progressbar" aria-valuenow="0" aria-valuemin="0" aria-valuemax="100" id="progressBarWrapper">
                    <div class="progress-fill" id="progressFill" style="width: 0%"></div>
                </div>
            </div>
        </section>

        <!-- Toolbar -->
        <section class="toolbar" aria-label="Actions toolbar">
            <div class="toolbar-left">
                <button class="btn btn-primary" id="addVideoBtn" onclick="addVideo()" title="Add Video (Ctrl+N)" aria-label="Add a new video">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
                    Add Video
                </button>
                <button class="btn btn-accent" onclick="showFetchModal()" aria-label="Auto-fetch a YouTube playlist">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
                    Auto-Fetch Playlist
                </button>
                <div class="btn-group">
                    <button class="btn btn-secondary" onclick="exportToCSV()" aria-label="Export to CSV">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
                        Export CSV
                    </button>
                    <button class="btn btn-secondary" onclick="importFromCSV()" aria-label="Import from CSV">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4"/><polyline points="17 8 12 3 7 8"/><line x1="12" y1="3" x2="12" y2="15"/></svg>
                        Import CSV
                    </button>
                </div>
                <input type="file" id="csvFile" accept=".csv" style="display: none;" onchange="handleFileImport(event)">
            </div>
            <div class="toolbar-right">
                <div class="search-wrapper">
                    <svg class="search-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
                    <input type="search" class="search-box" id="searchBox" placeholder="Search videos, notes..." oninput="filterVideos()" aria-label="Search videos">
                </div>
            </div>
        </section>

        <!-- Filter Tabs -->
        <nav class="filter-tabs" role="tablist" aria-label="Filter videos by status">
            <button class="filter-tab active" role="tab" aria-selected="true" data-filter="all" onclick="setFilter(this, 'all')">All</button>
            <button class="filter-tab" role="tab" aria-selected="false" data-filter="not-started" onclick="setFilter(this, 'not-started')">
                <span class="tab-dot dot-pending"></span> Not Started
            </button>
            <button class="filter-tab" role="tab" aria-selected="false" data-filter="in-progress" onclick="setFilter(this, 'in-progress')">
                <span class="tab-dot dot-inprogress"></span> In Progress
            </button>
            <button class="filter-tab" role="tab" aria-selected="false" data-filter="completed" onclick="setFilter(this, 'completed')">
                <span class="tab-dot dot-completed"></span> Completed
            </button>
            <button class="filter-tab" role="tab" aria-selected="false" data-filter="skipped" onclick="setFilter(this, 'skipped')">
                <span class="tab-dot dot-skipped"></span> Skipped
            </button>
        </nav>

        <!-- Table -->
        <div class="table-wrapper">
            <div class="table-container" role="region" aria-label="Video list">
                <table id="videoTable" aria-label="Playlist videos">
                    <thead>
                        <tr>
                            <th scope="col" style="width:50px">#</th>
                            <th scope="col">Video Title</th>
                            <th scope="col" style="width:110px">Watch</th>
                            <th scope="col" style="width:155px">Status</th>
                            <th scope="col" style="width:130px">Started</th>
                            <th scope="col" style="width:130px">Completed</th>
                            <th scope="col" style="width:90px">Duration</th>
                            <th scope="col">Notes</th>
                            <th scope="col" style="width:60px">Del</th>
                        </tr>
                    </thead>
                    <tbody id="videoTableBody">
                        <!-- JS-populated -->
                    </tbody>
                </table>
                <div id="emptyState" class="empty-state" aria-live="polite">
                    <div class="empty-icon">🎬</div>
                    <h3>No videos yet</h3>
                    <p>Add videos manually or auto-fetch an entire YouTube playlist in one click.</p>
                    <button class="btn btn-primary" onclick="showFetchModal()">Auto-Fetch Playlist</button>
                </div>
            </div>
        </div>

        <!-- How-to Section -->
        <section class="howto-section" aria-labelledby="howtoTitle">
            <h2 id="howtoTitle">How It Works</h2>
            <div class="howto-grid">
                <article class="howto-card">
                    <div class="howto-icon">🔑</div>
                    <h3>Get a Free API Key</h3>
                    <p>Visit <a href="https://console.developers.google.com/" target="_blank" rel="noopener">Google Cloud Console</a>, enable the YouTube Data API v3, and create a free API key.</p>
                </article>
                <article class="howto-card">
                    <div class="howto-icon">🚀</div>
                    <h3>Auto-Fetch Playlist</h3>
                    <p>Paste any YouTube playlist URL + your API key, hit fetch — all videos load instantly.</p>
                </article>
                <article class="howto-card">
                    <div class="howto-icon">📊</div>
                    <h3>Track Progress</h3>
                    <p>Mark each video as Not Started, In Progress, Completed, or Skipped. Watch your stats update live.</p>
                </article>
                <article class="howto-card">
                    <div class="howto-icon">💾</div>
                    <h3>Export Anytime</h3>
                    <p>Export your entire progress as a CSV file or import a previous session. Your data is also auto-saved locally.</p>
                </article>
            </div>
        </section>

    </main>

    <!-- Footer -->
    <footer class="site-footer" role="contentinfo">
        <div class="footer-inner">
            <span class="footer-brand">
                <span class="logo-i">I</span><span class="logo-love">Love</span><span class="logo-product">Playlist</span>
            </span>
            <span class="footer-sep">·</span>
            <span>Free YouTube Playlist Tracker</span>
            <span class="footer-sep">·</span>
            <a href="https://www.linkedin.com/in/harsh-kumar-b0b879245/" target="_blank" rel="noopener" aria-label="LinkedIn profile of HRS">Made with ❤️ by HRS</a>
        </div>
    </footer>

    <!-- ========== MODALS ========== -->

    <!-- Add Video Modal -->
    <div id="addVideoModal" class="modal" role="dialog" aria-modal="true" aria-labelledby="addVideoTitle">
        <div class="modal-backdrop" onclick="closeModal()"></div>
        <div class="modal-card">
            <div class="modal-header">
                <h2 id="addVideoTitle">➕ Add New Video</h2>
                <button class="modal-close" onclick="closeModal()" aria-label="Close modal">✕</button>
            </div>
            <div class="form-group">
                <label for="videoTitle">Video Title <span class="required">*</span></label>
                <input type="text" id="videoTitle" placeholder="e.g., JavaScript Fundamentals" autocomplete="off">
            </div>
            <div class="form-group">
                <label for="videoUrl">Video URL</label>
                <input type="url" id="videoUrl" placeholder="https://youtube.com/watch?v=...">
            </div>
            <div class="form-group">
                <label for="videoDuration">Duration <span class="optional">(optional)</span></label>
                <input type="text" id="videoDuration" placeholder="e.g., 15:30">
            </div>
            <div class="modal-footer">
                <button class="btn btn-ghost" onclick="closeModal()">Cancel</button>
                <button class="btn btn-primary" onclick="saveVideo()">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
                    Add Video
                </button>
            </div>
        </div>
    </div>

    <!-- Fetch Modal -->
    <div id="fetchModal" class="modal" role="dialog" aria-modal="true" aria-labelledby="fetchTitle">
        <div class="modal-backdrop" onclick="closeFetchModal()"></div>
        <div class="modal-card modal-wide">
            <div class="modal-header">
                <h2 id="fetchTitle">🚀 Auto-Fetch Playlist</h2>
                <button class="modal-close" onclick="closeFetchModal()" aria-label="Close modal">✕</button>
            </div>
            <p class="modal-desc">Enter your YouTube playlist URL and a free Google API key to automatically import all videos.</p>

            <div class="fetch-method-card selected" onclick="selectFetchMethod('api')">
                <input type="radio" name="fetchMethod" value="api" id="apiMethod" checked>
                <label for="apiMethod">
                    <strong>🔑 YouTube Data API v3</strong>
                    <span>Most reliable · Gets complete video data · Free API key required</span>
                </label>
            </div>

            <div id="fetchInputs" class="fetch-inputs"></div>

            <div class="modal-footer">
                <button class="btn btn-ghost" onclick="closeFetchModal()">Cancel</button>
                <button class="btn btn-primary" id="fetchButton" onclick="startFetch()" disabled>
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
                    Fetch Playlist
                </button>
            </div>
        </div>
    </div>

    <!-- Loading Modal -->
    <div id="loadingModal" class="modal" role="dialog" aria-modal="true" aria-labelledby="loadingTitle" aria-live="assertive">
        <div class="modal-card modal-loading">
            <div class="spinner" aria-hidden="true"></div>
            <h2 id="loadingTitle">Fetching Playlist…</h2>
            <p id="loadingStatus">Connecting to YouTube…</p>
            <button class="btn btn-ghost" onclick="cancelFetch()">Cancel</button>
        </div>
    </div>

    <script src="script.js"></script>
</body>
</html>